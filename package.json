{
  "name": "@dvashim/changesets-gitlab",
  "version": "0.0.2",
  "keywords": [
    "@changesets/cli",
    "auto-release",
    "changelog",
    "changeset",
    "changesets",
    "ci",
    "gitlab",
    "release"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dvashim/changesets-gitlab.git"
  },
  "license": "MIT",
  "author": "Aleksei Reznichenko <aleksei@dvashim.dev>",
  "contributors": [
    "JounQin <admin@1stg.me>"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "module-sync": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "require": {
        "types": "./index.d.cts",
        "default": "./lib/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./lib/index.cjs",
  "module": "./lib/index.js",
  "types": "./index.d.cts",
  "bin": "lib/cli.js",
  "files": [
    "index.d.cts",
    "lib"
  ],
  "scripts": {
    "build": "pnpm run \"/^build:.*/\"",
    "build:r": "r -f cjs --esbuild '{\"target\":\"es2020\"}'",
    "build:ts": "tsc -p tsconfig.lib.json",
    "clean": "rm -rf lib coverage *.tsbuildinfo",
    "cli": "tsx src/cli",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:biome": "biome check",
    "lint:tsc": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@changesets/assemble-release-plan": "^6.0.9",
    "@changesets/config": "^3.1.3",
    "@changesets/errors": "^0.2.0",
    "@changesets/parse": "^0.4.3",
    "@changesets/pre": "^2.0.2",
    "@changesets/read": "^0.6.7",
    "@changesets/types": "^6.1.0",
    "@gitbeaker/core": "^43.8.0",
    "@gitbeaker/rest": "^43.8.0",
    "@manypkg/get-packages": "^3.1.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "global-agent": "^4.1.3",
    "human-id": "^4.1.3",
    "markdown-table": "^3.0.4",
    "mdast-util-to-string": "^4.0.0",
    "micromatch": "^4.0.8",
    "p-limit": "^7.3.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "resolve-from": "^5.0.0",
    "semver": "^7.7.4",
    "tslib": "^2.8.1",
    "unified": "^11.0.5",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@dvashim/biome-config": "^1.4.0",
    "@pkgr/rollup": "^7.0.1",
    "@types/global-agent": "^3.0.0",
    "@types/micromatch": "^4.0.10",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-istanbul": "4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
