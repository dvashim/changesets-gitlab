{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2024",
    "declaration": true,
    "outDir": "lib",
    "removeComments": true,
    "importHelpers": true,
    "incremental": true,
    "lib": ["ESNext"],
    "newLine": "lf",
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "rewriteRelativeImportExtensions": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "stripInternal": true,
    "verbatimModuleSyntax": true
  },
  "exclude": ["lib"]
}
